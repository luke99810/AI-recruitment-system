# AI 智能招聘系统 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ===== LLM 配置（必填）=====
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ===== 服务配置 =====
HOST=127.0.0.1
PORT=8501

# ===== TTS 配置（可选）=====
# TTS_ENGINE=edge-tts
# 使用讯飞TTS时取消下面注释并填入
# XUNFEI_APP_ID=
# XUNFEI_API_KEY=
# XUNFEI_API_SECRET=
